{
    "cli": {
        "version": ">= 7.4.0"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "resourceClass": "large"
            },
            "env": {
                "APP_VARIANT": "development"
            }
        },
        "development-simulator": {
            "extends": "development",
            "ios": {
                "simulator": true
            }
        },
        "preview": {
            "distribution": "internal"
        },
        "production": {
            "channel": "production"
        }
    },
    "submit": {
        "production": {}
    }
}
